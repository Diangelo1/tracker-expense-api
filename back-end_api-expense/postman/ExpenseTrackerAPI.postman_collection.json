{
  "info": {
    "name": "Expense Tracker API",
    "description": "Collection para testar a API de controle de despesas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "categoriaId", "value": "1" },
    { "key": "expenseId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Cadastrar usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva\",\n  \"email\": \"maria@example.com\",\n  \"senha\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('token', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria@example.com\",\n  \"senha\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Categorias",
      "item": [
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Detalhar categoria",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/categories/{{categoriaId}}"
          }
        },
        {
          "name": "Criar categoria",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Educação\",\n  \"descricao\": \"Cursos e livros\"\n}"
            }
          }
        },
        {
          "name": "Atualizar categoria",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/categories/{{categoriaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Educação\",\n  \"descricao\": \"Cursos, livros e cursos online\"\n}"
            }
          }
        },
        {
          "name": "Excluir categoria",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/categories/{{categoriaId}}"
          }
        }
      ]
    },
    {
      "name": "Despesas",
      "item": [
        {
          "name": "Listar despesas (com filtros)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/expenses?status=PAGA&categoria={{categoriaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["expenses"],
              "query": [
                { "key": "status", "value": "PAGA" },
                { "key": "categoria", "value": "{{categoriaId}}" }
              ]
            }
          }
        },
        {
          "name": "Detalhar despesa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/expenses/{{expenseId}}"
          }
        },
        {
          "name": "Criar despesa",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/expenses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"Supermercado\",\n  \"valor\": 250.5,\n  \"data\": \"2026-06-15\",\n  \"status\": \"PENDENTE\",\n  \"categoriaId\": {{categoriaId}}\n}"
            }
          }
        },
        {
          "name": "Atualizar despesa",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/expenses/{{expenseId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"Supermercado do mês\",\n  \"valor\": 300,\n  \"data\": \"2026-06-15\",\n  \"status\": \"PAGA\",\n  \"categoriaId\": {{categoriaId}}\n}"
            }
          }
        },
        {
          "name": "Excluir despesa",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/expenses/{{expenseId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Total de gastos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/total-expenses"
          }
        },
        {
          "name": "Quantidade de despesas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/expenses-count"
          }
        },
        {
          "name": "Gastos por categoria",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/expenses-by-category"
          }
        }
      ]
    }
  ]
}
